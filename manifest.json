{
  "manifest_version": 3,
  "name": "H Chat - AI 올인원 어시스턴트",
  "version": "5.7.0",
  "description": "Claude, GPT, Gemini를 사이드바에서. 페이지 요약·번역·글쓰기·그룹채팅·프롬프트 라이브러리.",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "H Chat 열기",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png" }
  },

  "side_panel": { "default_path": "sidepanel.html" },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.google.co.kr/search*",
        "https://www.bing.com/search*",
        "https://search.naver.com/search*"
      ],
      "js": ["search-injector.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["writing-assistant.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "sidePanel",
    "contextMenus",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+H", "mac": "MacCtrl+Shift+H" },
      "description": "H Chat 사이드패널 열기"
    },
    "quick-summarize": {
      "suggested_key": { "default": "Ctrl+Shift+S", "mac": "MacCtrl+Shift+S" },
      "description": "현재 페이지 빠른 요약"
    }
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
